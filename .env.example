# Environment for Taskfile operations.
#
# Copy this file to `.env` (Taskfile loads it via `dotenv: ['.env']`):
#   task setup:prepare      # or: cp .env.example .env
#
# `.env` is git-ignored. Shell environment variables override values set here.
# Uncomment and fill in the variables you need.

# ── AWS Amplify sandbox ────────────────────────────────────────────────────
# Required by every `task amplify:*` operation (guarded by `amplify:checks`).

# AWS named profile used to reach your dev account.
# AWS_PROFILE=

# Name of your Amplify sandbox stack (per-developer, must be unique).
# SANDBOX_STACK_NAME=

# ── Stripe (billing) ───────────────────────────────────────────────────────
# Required by `task amplify:sandbox:secrets` (sets the sandbox secret) and by
# `task backend:sandbox:seed:plans` (syncs plans FROM Stripe). Use a TEST key.
# STRIPE_SECRET_KEY=

# Stripe webhook forwarding target for `task billing:stripe:listen`. Point it at
# `custom.stripeWebhookUrl` from the generated amplify_outputs.json.
# STRIPE_WEBHOOK_URL=
