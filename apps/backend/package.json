{
  "name": "@starter-nuxt-amplify-saas/backend",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "exports": {
    "./schema": "./amplify/data/resource.ts"
  },
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "deploy": "pnpm exec ampx pipeline-deploy --branch $AWS_BRANCH --app-id $AWS_APP_ID",
    "sandbox:init": "pnpm exec ampx sandbox",
    "sandbox:delete": "pnpm exec ampx sandbox delete",
    "sandbox:secrets": "printf %s \"$STRIPE_SECRET_KEY\" | pnpm exec ampx sandbox secret set STRIPE_SECRET_KEY && printf %s \"$STRIPE_WEBHOOK_SECRET\" | pnpm exec ampx sandbox secret set STRIPE_WEBHOOK_SECRET",
    "seed": "pnpm exec ampx sandbox seed",
    "seed:plans": "SEED_TASK=plans pnpm exec ampx sandbox seed",
    "seed:users": "SEED_TASK=users pnpm exec ampx sandbox seed",
    "seed:stripe": "stripe fixtures amplify/seed/data/stripe.json --api-key $STRIPE_SECRET_KEY",
    "sandbox:generate-outputs": "pnpm exec ampx generate outputs",
    "sandbox:generate-graphql-client-code": "pnpm exec ampx generate graphql-client-code",
    "generate-outputs": "pnpm exec ampx generate outputs --branch $AWS_BRANCH --app-id $AWS_APP_ID",
    "generate-graphql-client-code": "pnpm exec ampx generate graphql-client-code --branch $AWS_BRANCH --app-id $AWS_APP_ID",
    "stripe:listen": "stripe listen --forward-to \"${STRIPE_WEBHOOK_URL:?Set STRIPE_WEBHOOK_URL to the stripe-webhook Function URL (custom.stripeWebhookUrl in amplify_outputs.json)}\"",
    "sandbox:stripe:seed": "stripe fixtures --api-key $STRIPE_SECRET_KEY"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.13.1",
  "devDependencies": {
    "@aws-amplify/backend": "^1.23.0",
    "@aws-amplify/backend-cli": "^1.8.3",
    "@aws-amplify/seed": "^1.1.3",
    "@types/aws-lambda": "^8.10.159",
    "aws-cdk-lib": "2.261.0",
    "constructs": "^10.6.0",
    "esbuild": "^0.28.1",
    "stripe": "^18.5.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@aws-sdk/client-cognito-identity-provider": "^3.700.0",
    "@mmshark/amplify-layer": "workspace:*",
    "@mmshark/billing-layer": "workspace:*",
    "aws-amplify": "^6.15.8",
    "zod": "^4.4.3"
  }
}
