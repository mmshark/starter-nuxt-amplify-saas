{
  "name": "@starter-nuxt-amplify-saas/saas",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "typecheck": "nuxt typecheck",
    "postinstall": "nuxt prepare",
    "test:e2e": "playwright test -c tests/e2e/playwright.config.js tests/e2e/specs/",
    "test:e2e:auth": "playwright test -c tests/e2e/playwright.config.js tests/e2e/specs/layers/auth/",
    "test:e2e:auth:signup": "playwright test -c tests/e2e/playwright.config.js tests/e2e/specs/layers/auth/signup.spec.js",
    "test:e2e:auth:signin": "playwright test -c tests/e2e/playwright.config.js tests/e2e/specs/layers/auth/signin.spec.js",
    "test:e2e:billing": "playwright test -c tests/e2e/playwright.config.js tests/e2e/specs/layers/billing/",
    "test:e2e:billing:plans": "playwright test -c tests/e2e/playwright.config.js tests/e2e/specs/layers/billing/plans.spec.js",
    "test:e2e:flows": "playwright test -c tests/e2e/playwright.config.js tests/e2e/specs/flows/",
    "test:e2e:flow:new-user-journey": "playwright test -c tests/e2e/playwright.config.js tests/e2e/specs/flows/new-user-journey.spec.js",
    "test:e2e:individual": "playwright test -c tests/e2e/playwright.config.js --project=individual",
    "test:e2e:headed": "playwright test -c tests/e2e/playwright.config.js tests/e2e/specs/ --headed",
    "test:e2e:debug": "playwright test -c tests/e2e/playwright.config.js tests/e2e/specs/ --debug",
    "test:e2e:ui": "playwright test -c tests/e2e/playwright.config.js tests/e2e/specs/ --ui",
    "test:e2e:setup": "playwright install chromium",
    "test:e2e:clean": "rm -rf tests/e2e/.cache/"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@iconify-json/lucide": "^1.2.77",
    "@mmshark/saas-layer": "workspace:*",
    "@mmshark/debug-layer": "workspace:*",
    "@vue/server-renderer": "3.5.39",
    "nuxt": "^4.4.8",
    "vue": "3.5.39",
    "vue-router": "^4.6.3"
  },
  "devDependencies": {
    "@nuxt/ui": "^4.9.0",
    "@playwright/test": "^1.57.0",
    "mailparser": "^3.9.0",
    "node-imap": "^0.9.6",
    "playwright": "^1.57.0",
    "typescript": "^5.9.3",
    "vue-tsc": "^3.3.6",
    "zod": "^4.4.3"
  }
}
