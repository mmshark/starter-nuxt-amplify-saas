# Base URL of the app, used to build Stripe checkout/portal redirect URLs.
# Must NOT be derived from request headers (Host / X-Forwarded-*) — those are
# attacker-controlled. Set to your real deployed origin in production.
APP_BASE_URL=http://localhost:3000

# Stripe Configuration
# Get these from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your_secret_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here

# Stripe Webhook Secret
# NOT read by the Nuxt app: the webhook endpoint is the stripe-webhook
# Lambda's Function URL (custom.stripeWebhookUrl in amplify_outputs.json).
# Set the secret as an Amplify secret instead:
#   printf %s "$STRIPE_WEBHOOK_SECRET" | pnpm exec ampx sandbox secret set STRIPE_WEBHOOK_SECRET
# (or via the Amplify console for branch deployments), using the signing
# secret from https://dashboard.stripe.com/webhooks for that endpoint.

# Notes:
# 1. Copy this file to .env in your project root
# 2. Replace the placeholder values with your actual Stripe keys
# 3. For production, use live keys (sk_live_... and pk_live_...)
# 4. Never commit your .env file to git - it should be in .gitignore