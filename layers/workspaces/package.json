    "saas",
    "workspaces",
    "multi-tenancy",
    "teams",
    "collaboration",
    "invitations"
  ],
  "author": "MMShark",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mmshark/starter-nuxt-amplify-saas.git",
    "directory": "layers/workspaces"
  },
  "bugs": {
    "url": "https://github.com/mmshark/starter-nuxt-amplify-saas/issues"
  },
  "homepage": "https://github.com/mmshark/starter-nuxt-amplify-saas/tree/master/layers/workspaces#readme",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
