{
  "name": "@mmshark/workspaces-layer",
  "version": "0.1.0",
  "description": "Multi-tenant workspace management with team collaboration and invitations",
  "type": "module",
  "main": "./nuxt.config.ts",
  "exports": {
    ".": "./nuxt.config.ts",
    "./composables/*": "./composables/*",
    "./components/*": "./components/*",
    "./types/*": "./types/*"
  },
  "files": [
    "nuxt.config.ts",
    "components",
    "composables",
    "server",
    "types",
    "README.md"
  ],
  "keywords": [
    "nuxt",
    "nuxt-layer",
