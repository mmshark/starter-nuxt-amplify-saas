    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@mmshark/auth-layer": "workspace:*",
    "@mmshark/billing-layer": "workspace:*",
    "@mmshark/entitlements-layer": "workspace:*",
    "@mmshark/uix-layer": "workspace:*"
  }
