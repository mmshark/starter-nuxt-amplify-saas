{
  "name": "starter-nuxt-amplify-saas",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "layers/*"
  ],
  "scripts": {
    "// --- Sandbox Commands ---": "",
    "backend:sandbox:init": "pnpm --filter @starter-nuxt-amplify-saas/backend run sandbox:init",
    "backend:sandbox:delete": "pnpm --filter @starter-nuxt-amplify-saas/backend run sandbox:delete -y",
    "backend:sandbox:secrets": "pnpm --filter @starter-nuxt-amplify-saas/backend run sandbox:secrets",
    "billing:sandbox:stripe:seed": "pnpm --filter @starter-nuxt-amplify-saas/backend run sandbox:stripe:seed -- amplify/seed/data/stripe.json",
    "backend:sandbox:seed": "pnpm --filter @starter-nuxt-amplify-saas/backend run seed",
    "backend:sandbox:seed:plans": "pnpm --filter @starter-nuxt-amplify-saas/backend run seed:plans",
    "backend:sandbox:seed:users": "pnpm --filter @starter-nuxt-amplify-saas/backend run seed:users",
    "amplify:outputs:stub": "cp layers/amplify/amplify_outputs.stub.json layers/amplify/amplify_outputs.json",
    "amplify:sandbox:generate-outputs": "pnpm --filter @starter-nuxt-amplify-saas/backend run sandbox:generate-outputs",
    "amplify:sandbox:generate-graphql-client-code": "pnpm --filter @starter-nuxt-amplify-saas/backend run sandbox:generate-graphql-client-code",
    "saas:dev": "pnpm --filter @starter-nuxt-amplify-saas/saas run dev",
    "saas:build": "pnpm --filter @starter-nuxt-amplify-saas/saas run build",
    "landing:dev": "pnpm --filter @starter-nuxt-amplify-saas/landing run dev",
    "landing:build": "pnpm --filter @starter-nuxt-amplify-saas/landing run build",
    "landing:generate": "pnpm --filter @starter-nuxt-amplify-saas/landing run generate",
    "amplify:generate-graphql-client-code": "pnpm --filter @starter-nuxt-amplify-saas/backend run generate-graphql-client-code",
    "amplify:generate-outputs": "pnpm --filter @starter-nuxt-amplify-saas/backend run generate-outputs",
    "billing:stripe:login": "stripe login",
    "billing:stripe:listen": "pnpm --filter @starter-nuxt-amplify-saas/backend run stripe:listen",
    "// --- E2E Testing ---": "",
    "saas:test:e2e": "pnpm --filter @starter-nuxt-amplify-saas/saas run test:e2e",
    "saas:test:e2e:auth": "pnpm --filter @starter-nuxt-amplify-saas/saas run test:e2e:auth",
    "saas:test:e2e:billing": "pnpm --filter @starter-nuxt-amplify-saas/saas run test:e2e:billing",
    "saas:test:e2e:headed": "pnpm --filter @starter-nuxt-amplify-saas/saas run test:e2e:headed",
    "saas:test:e2e:ui": "pnpm --filter @starter-nuxt-amplify-saas/saas run test:e2e:ui",
    "saas:test:e2e:clean": "pnpm --filter @starter-nuxt-amplify-saas/saas run test:e2e:clean",
    "saas:test:e2e:setup": "pnpm --filter @starter-nuxt-amplify-saas/saas run test:e2e:setup",
    "// --- Tooling ---": "",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run"
  },
  "devDependencies": {
    "@aws-amplify/backend-cli": "^1.8.3",
    "@nuxt/eslint-config": "^1.16.0",
    "dotenv": "^17.2.3",
    "eslint": "^10.6.0",
    "stripe": "^18.5.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.10"
  },
  "packageManager": "pnpm@10.13.1",
  "engines": {
    "node": ">=22"
  },
  "pnpm": {
    "overrides": {
      "@aws-amplify/api-graphql": "4.8.8",
      "aws-amplify": "6.18.0"
    },
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "@tailwindcss/oxide",
      "better-sqlite3",
      "core-js",
      "esbuild",
      "maplibre-gl",
      "unrs-resolver",
      "vue-demi"
    ]
  }
}
